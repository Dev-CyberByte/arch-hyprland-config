configuration {
    modi:           "drun,run,window";
    show-icons:     true;
    icon-theme:     "Papirus-Dark";
    font:           "JetBrainsMono Nerd Font 13";
    drun-display-format: "{name}";
    display-drun:   "  Apps";
    display-run:    "  Run";
    display-window: "  Windows";
    hover-select:   true;
    me-select-entry: "";
    me-accept-entry: "MousePrimary";
}

@theme "~/.config/rofi/cyberpunk.rasi"
